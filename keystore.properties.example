# Скопируйте этот файл в keystore.properties (он в .gitignore) и заполните своими данными.
# Создать keystore: keytool -genkey -v -keystore release.jks -keyalg RSA -keysize 2048 -validity 10000 -alias ecopulse
storeFile=../release.jks
storePassword=ВАШ_ПАРОЛЬ_ХРАНИЛИЩА
keyAlias=ecopulse
keyPassword=ВАШ_ПАРОЛЬ_КЛЮЧА
